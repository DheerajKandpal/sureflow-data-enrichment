# ─────────────────────────────────────────────────────────────────────────────
# SureFlow — Environment Template
# Copy this file to .env and fill in your values.
# .env is gitignored — .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Demo mode: "true" → offline MockProvider, no credentials required
# Demo mode: "false" → RealProvider (requires Surepass tokens)
DEMO_MODE=true

# Surepass API tokens (only needed when DEMO_MODE=false)
SUREPASS_PRIMARY_TOKEN=your_primary_token_here
SUREPASS_SECONDARY_TOKEN=your_secondary_token_here

# SQLite database path
DB_PATH=data/jobs.db

# Log verbosity
LOG_LEVEL=INFO
